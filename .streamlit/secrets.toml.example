# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Secrets Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this content into:
#   Streamlit Cloud → Your App → ⋮ → Settings → Secrets
#
# For LOCAL development, copy .env.example to .env instead.
# ─────────────────────────────────────────────────────────────────────────────

# Required — Dhan API credentials
DHAN_CLIENT_ID = "your_client_id_here"
DHAN_PIN       = "your_5_digit_pin"

# Optional — access token (generated via TOTP in the Dhan Auth tab)
# If left blank, authenticate via the 🔐 Dhan Auth tab each session.
DHAN_ACCESS_TOKEN = ""

# Optional — Hugging Face (for historical data caching)
HF_TOKEN       = "your_hf_token"
HF_DATASET_REPO = "your-username/nse-dhan-ohlc"
