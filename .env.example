# ─── Dhan API Credentials ─────────────────────────────────────────────────────
# Get these from your Dhan trading account

# Your Dhan Client ID (visible in the Dhan app under Profile)
DHAN_CLIENT_ID=your_client_id_here

# Your Dhan 5-digit PIN (same PIN you use to log in to Dhan)
DHAN_PIN=your_5_digit_pin_here

# Access token — generated automatically via the 🔐 Dhan Auth tab in the app.
# You do NOT need to fill this manually; the app saves it after TOTP authentication.
DHAN_ACCESS_TOKEN=

# ─── Hugging Face (optional — for data caching) ───────────────────────────────
# Create a dataset repo at https://huggingface.co/new-dataset
# Get a write token from https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here
HF_DATASET_REPO=your-username/nse-dhan-ohlc
